{
  "browser": {
    "channel": "chrome",
    "headless": false,
    "chromiumSandbox": false,
    "userDataDir": "%USERPROFILE%/.genai-traffic-harness/chrome-profile",
    "profileDirectory": "",
    "viewport": {
      "width": 1440,
      "height": 950
    }
  },
  "run": {
    "sessions": 16,
    "minDelayMs": 4000,
    "maxDelayMs": 14000,
    "defaultTimeoutMs": 45000,
    "downloadDir": "downloads",
    "deleteDownloads": true,
    "logFile": "runs.jsonl",
    "allowUploads": true,
    "uploadProbability": 0.12,
    "multiTurnProbability": 0.4,
    "maxChatTurns": 3,
    "promptCategories": [
      "genai",
      "embedded-ai",
      "business",
      "software",
      "policy",
      "creative"
    ]
  },
  "targets": [
    {
      "name": "ChatGPT",
      "enabled": true,
      "kind": "chat",
      "weight": 8,
      "url": "https://chatgpt.com/",
      "uploadProbability": 0.28,
      "conversation": {
        "multiTurnProbability": 0.5,
        "maxTurns": 3
      },
      "promptCategories": ["genai", "software", "creative", "policy"],
      "auth": {
        "googleSelectors": ["button:has-text('Continue with Google')", "text=/continue with google/i"],
        "guestSelectors": ["text=/try it first/i", "a:has-text('Try it first')", "button:has-text('Try it first')"]
      },
      "selectors": {
        "input": ["textarea", "[contenteditable='true']", "[role='textbox']"],
        "send": ["button[aria-label*='Send' i]", "button[data-testid*='send' i]", "button[type='submit']"],
        "attach": ["button[aria-label*='Attach' i]", "button[aria-label*='Upload' i]", "button:has-text('Attach')"]
      }
    },
    {
      "name": "Claude Web",
      "enabled": true,
      "kind": "chat",
      "weight": 7,
      "url": "https://claude.ai/",
      "uploadProbability": 0.28,
      "conversation": {
        "multiTurnProbability": 0.5,
        "maxTurns": 3
      },
      "promptCategories": ["genai", "business", "software", "embedded-ai"],
      "auth": {
        "googleSelectors": ["button:has-text('Continue with Google')", "text=/continue with google/i"]
      },
      "selectors": {
        "input": ["textarea", "[contenteditable='true']", "[role='textbox']"],
        "send": ["button[aria-label*='Send' i]", "button[type='submit']"],
        "attach": ["button[aria-label*='Attach' i]", "button[aria-label*='Upload' i]", "button:has-text('Attach')"]
      }
    },
    {
      "name": "Perplexity",
      "enabled": true,
      "kind": "chat",
      "weight": 8,
      "url": "https://www.perplexity.ai/",
      "uploadProbability": 0.2,
      "conversation": {
        "multiTurnProbability": 0.35,
        "maxTurns": 2
      },
      "promptCategories": ["genai", "business", "software", "policy"],
      "auth": {
        "googleSelectors": ["button:has-text('Continue with Google')", "text=/continue with google/i"],
        "guestSelectors": ["text=/continue as guest/i", "text=/try without/i", "button:has-text('Continue as guest')"]
      },
      "selectors": {
        "input": ["textarea", "[contenteditable='true']", "[role='textbox']"],
        "send": ["button[aria-label*='Submit' i]", "button[aria-label*='Send' i]", "button[type='submit']"],
        "attach": ["button[aria-label*='Attach' i]", "button[aria-label*='Upload' i]", "button:has-text('Attach')"]
      }
    },
    {
      "name": "DeepSeek",
      "enabled": true,
      "kind": "isolated-chat",
      "url": "https://chat.deepseek.com/",
      "uploadProbability": 0,
      "promptCategories": ["genai", "software", "business"],
      "isolation": {
        "settleMs": 15000,
        "inputClick": {
          "xRatio": 0.5,
          "yRatio": 0.86
        }
      },
      "auth": {
        "googleSelectors": ["button:has-text('Continue with Google')", "text=/continue with google/i"]
      },
      "selectors": {
        "input": ["textarea", "[contenteditable='true']", "[role='textbox']"],
        "send": ["button[aria-label*='Send' i]", "button[type='submit']"],
        "attach": ["button[aria-label*='Attach' i]", "button[aria-label*='Upload' i]", "button:has-text('Attach')"]
      }
    },
    {
      "name": "Google Gemini",
