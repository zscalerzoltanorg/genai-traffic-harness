{
  "name": "genai-traffic-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Config-driven browser automation harness for GenAI and embedded AI SaaS usage simulation.",
  "scripts": {
    "setup:chrome": "powershell -ExecutionPolicy Bypass -File scripts/setup-chrome-default.ps1",
    "install:browsers": "playwright install chromium",
    "fixtures": "node src/generate-fixtures.mjs",
    "run": "node src/runner.mjs",
    "run:all": "powershell -ExecutionPolicy Bypass -File scripts/run-all.ps1",
    "run:dry": "node src/runner.mjs --dry-run --sessions=5 --no-delay",
    "check": "node --check src/runner.mjs && node --check src/generate-fixtures.mjs"
  },
  "dependencies": {
    "playwright": "^1.45.0"
  },
  "engines": {
    "node": ">=20"
  }
}
