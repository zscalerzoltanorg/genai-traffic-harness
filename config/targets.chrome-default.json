{
  "browser": {
    "channel": "chrome",
    "headless": false,
    "chromiumSandbox": false,
    "userDataDir": "%USERPROFILE%/.genai-traffic-harness/chrome-profile",
    "profileDirectory": "",
    "viewport": {
      "width": 1440,
      "height": 950
    }
  },
  "run": {
    "sessions": 16,
    "minDelayMs": 4000,
    "maxDelayMs": 14000,
    "defaultTimeoutMs": 45000,
    "downloadDir": "downloads",
    "deleteDownloads": true,
    "logFile": "runs.jsonl",
    "allowUploads": true,
    "uploadProbability": 0.12,
    "sensitivePromptProbability": 0.06,
    "sensitivePromptCategories": ["dlp-pci", "dlp-medical"],
    "multiTurnProbability": 0.4,
    "maxChatTurns": 3,
    "promptCategories": [
      "genai",
      "embedded-ai",
      "business",
      "software",
      "policy",
      "creative"
    ]
  },
  "browseQueries": [
    "enterprise AI agents platform",
    "Salesforce Agentforce use cases",
    "Google AI Mode enterprise search",
    "embedded AI copilot SaaS",
    "AI chatbot for customer support",
    "agentic AI workflow automation",
    "AI governance prompt inspection",
    "edge AI developer platform",
    "AI assistant for CRM",
    "AI code assistant enterprise",
    "AI meeting assistant SaaS",
    "multimodal AI app platform",
    "AI search assistant for work",
    "AI agent builder no code",
    "retrieval augmented generation platform"
  ],
  "targets": [
    {
      "name": "ChatGPT",
      "enabled": true,
      "kind": "chat",
      "weight": 8,
      "url": "https://chatgpt.com/",
      "uploadProbability": 0.28,
      "conversation": {
        "multiTurnProbability": 0.5,
        "maxTurns": 3
      },
      "promptCategories": ["genai", "software", "creative", "policy"],
      "auth": {
        "googleSelectors": ["button:has-text('Continue with Google')", "text=/continue with google/i"],
        "guestSelectors": ["text=/try it first/i", "a:has-text('Try it first')", "button:has-text('Try it first')"]
      },
      "selectors": {
        "input": ["textarea", "[contenteditable='true']", "[role='textbox']"],
        "send": ["button[aria-label*='Send' i]", "button[data-testid*='send' i]", "button[type='submit']"],
        "attach": ["button[aria-label*='Attach' i]", "button[aria-label*='Upload' i]", "button:has-text('Attach')"]
      }
    },
    {
      "name": "Claude Web",
      "enabled": true,
      "kind": "chat",
      "weight": 7,
      "url": "https://claude.ai/",
