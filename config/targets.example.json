{
  "browser": {
    "channel": "msedge",
    "headless": false,
    "userDataDir": "",
    "profileDirectory": "",
    "viewport": {
      "width": 1440,
      "height": 950
    }
  },
  "run": {
    "sessions": 5,
    "minDelayMs": 3000,
    "maxDelayMs": 12000,
    "defaultTimeoutMs": 20000,
    "downloadDir": "downloads",
    "deleteDownloads": true,
    "logFile": "runs.jsonl",
    "allowUploads": true,
    "uploadProbability": 0.35,
    "promptCategories": [
      "genai",
      "embedded-ai",
      "business",
      "software",
      "policy",
      "creative"
    ]
  },
  "targets": [
    {
      "name": "ChatGPT",
      "enabled": false,
      "kind": "chat",
      "url": "https://chatgpt.com/",
      "promptCategories": ["genai", "software", "creative"],
      "selectors": {
        "input": [
          "textarea",
          "[contenteditable='true']",
          "[role='textbox']"
        ],
        "send": [
          "button[aria-label*='Send' i]",
          "button[data-testid*='send' i]"
        ],
        "attach": [
          "button[aria-label*='Attach' i]",
          "button[aria-label*='Upload' i]"
        ]
      }
    },
    {
      "name": "Claude",
      "enabled": false,
      "kind": "chat",
      "url": "https://claude.ai/",
      "promptCategories": ["genai", "business", "software"],
      "selectors": {
        "input": [
          "textarea",
          "[contenteditable='true']",
          "[role='textbox']"
        ],
        "send": [
          "button[aria-label*='Send' i]",
          "button[type='submit']"
        ],
        "attach": [
          "button[aria-label*='Attach' i]",
          "button[aria-label*='Upload' i]"
        ]
      }
    },
    {
      "name": "Microsoft Copilot",
      "enabled": false,
      "kind": "chat",
      "url": "https://copilot.microsoft.com/",
      "promptCategories": ["genai", "business", "software"],
      "selectors": {
        "input": [
          "textarea",
          "[contenteditable='true']",
          "[role='textbox']"
        ],
        "send": [
          "button[aria-label*='Send' i]",
          "button[type='submit']"
        ]
      }
    },
    {
      "name": "Generic SaaS Embedded Chatbot",
      "enabled": false,
      "kind": "embedded-chat",
      "url": "https://example.com/",
      "promptCategories": ["embedded-ai", "business", "policy"],
      "selectors": {
        "launcher": [
          "button[aria-label*='chat' i]",
          "button:has-text('Chat')",
          "[role='button']:has-text('Ask AI')",
          "[role='button']:has-text('Copilot')"
        ],
        "input": [
          "textarea",
          "[contenteditable='true']",
          "[role='textbox']"
        ],
        "send": [
          "button[aria-label*='Send' i]",
          "button[type='submit']"
        ]
      }
    },
    {
      "name": "AI Product Docs Browse",
      "enabled": true,
      "kind": "browse",
      "url": "https://learn.microsoft.com/en-us/azure/ai-services/",
      "maxClicks": 2
    },
    {
      "name": "NVIDIA Embedded AI Browse",
      "enabled": true,
      "kind": "browse",
      "url": "https://developer.nvidia.com/embedded-computing",
      "maxClicks": 2
    },
    {
      "name": "Local Fixture Download Smoke",
      "enabled": false,
      "kind": "download",
      "url": "https://file-examples.com/",
      "selectors": {
        "downloadLinks": [
          "a[href$='.pdf']",
          "a[href$='.docx']",
          "a[href$='.xlsx']",
          "a[href$='.csv']"
        ]
      }
    }
  ]
}
